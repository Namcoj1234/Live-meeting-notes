# Workspace partition key used in D1 rows.
WORKSPACE_CODE=LMN-PERSONAL

# Optional Smart Transcribe on Cloudflare Workers AI.
# Create an API token with Workers AI Read/Edit permission.
CLOUDFLARE_ACCOUNT_ID=YOUR-CLOUDFLARE-ACCOUNT-ID
CLOUDFLARE_AI_TOKEN=YOUR-CLOUDFLARE-WORKERS-AI-TOKEN
CLOUDFLARE_WHISPER_MODEL=@cf/openai/whisper-large-v3-turbo
CLOUDFLARE_TRANSLATE_MODEL=@cf/meta/m2m100-1.2b
CLOUDFLARE_INTERPRETER_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
